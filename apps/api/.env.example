# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://novus_user:SENHA_FORTE_AQUI@localhost:5432/novus_db"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://seudominio.com.br
UPLOAD_DIR=./uploads

# ─── Autenticação ─────────────────────────────────────────────────────────────
# Gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_ALEATORIA_LONGA

# ─── WhatsApp Business API ────────────────────────────────────────────────────
# Configure em: developers.facebook.com
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ─── Google Calendar / Meet ───────────────────────────────────────────────────
# Configure em: console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# ─── Gov.br OAuth2 (assinatura eletrônica gratuita) ──────────────────────────
# Cadastre em: gov.br/conecta/catalogo/apis/login-unico
GOVBR_ENV=production
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_REDIRECT_URI=https://seudominio.com.br/api/govbr/callback
